{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "types": [
      "node",
      "bun-types"
    ],
    "baseUrl": "."
  },
  "include": [
    "server.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "vite.config.ts"
  ]
}
